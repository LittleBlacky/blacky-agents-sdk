{
  "name": "blacky-agents-sdk",
  "version": "0.1.0",
  "description": "A TypeScript SDK for building classic LLM agent patterns.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "example:quickstart": "tsx src/examples/quickstart.ts"
  },
  "keywords": [
    "agents",
    "llm",
    "sdk",
    "typescript",
    "react",
    "tree-shaking"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^25.1.0",
    "dotenv": "^17.3.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.50.2",
    "rollup-plugin-dts": "^6.2.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
