{
  "name": "blacky-agents-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript SDK for building classic agent patterns (ReAct, Plan-and-Solve, Reflection).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && rollup -c",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/examples/quickstart.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^25.1.0",
    "rollup": "^4.50.1",
    "rollup-plugin-dts": "^6.2.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
